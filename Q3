#include <stdio.h>
#define MAX 100

int s[MAX], top = -1, n, ch, x, i;

int main() {
    printf("Enter size: ");
    scanf("%d", &n);

    if (n <= 0 || n > MAX) {
        printf("Invalid size\n");
        return 0;
    }

    while (1) {
        printf("\n1.Push 2.Pop 3.Display 4.Exit\nEnter choice: ");
        scanf("%d", &ch);

        switch (ch) {
            case 1:
                if (top == n - 1)
                    printf("Stack Overflow\n");
                else {
                    printf("Enter value: ");
                    scanf("%d", &x);
                    s[++top] = x;
                }
                break;

            case 2:
                if (top == -1)
                    printf("Stack Underflow\n");
                else
                    printf("Popped: %d\n", s[top--]);
                break;

            case 3:
                if (top == -1)
                    printf("Stack is empty\n");
                else {
                    printf("Stack:\n");
                    for (i = top; i >= 0; i--)
                        printf("%d\n", s[i]);
                }
                break;

            case 4:
                return 0;

            default:
                printf("Wrong choice\n");
        }
    }
}



#include <stdio.h>
#include <stdlib.h>

#define MAX 5

int q[MAX];
int front = -1, rear = -1;

void insert();
void del();     // 🔥 renamed (important fix)
void display();

int main() {
    int ch;

    while (1) {
        printf("\n1.Insert 2.Delete 3.Display 4.Exit\nChoice: ");
        scanf("%d", &ch);

        switch (ch) {
            case 1: insert(); break;
            case 2: del(); break;
            case 3: display(); break;
            case 4: exit(0);
            default: printf("Wrong choice\n");
        }
    }
}

void insert() {
    int x;

    if ((front == 0 && rear == MAX - 1) || (rear + 1 == front)) {
        printf("Overflow\n");
        return;
    }

    printf("Enter: ");
    scanf("%d", &x);

    if (front == -1)
        front = rear = 0;
    else if (rear == MAX - 1)
        rear = 0;
    else
        rear++;

    q[rear] = x;
}

void del() {
    if (front == -1) {
        printf("Underflow\n");
        return;
    }

    printf("Deleted: %d\n", q[front]);

    if (front == rear)
        front = rear = -1;
    else if (front == MAX - 1)
        front = 0;
    else
        front++;
}

void display() {
    int i;

    if (front == -1) {
        printf("Empty\n");
        return;
    }

    printf("Queue: ");

    if (front <= rear) {
        for (i = front; i <= rear; i++)
            printf("%d ", q[i]);
    } else {
        for (i = front; i < MAX; i++)
            printf("%d ", q[i]);
        for (i = 0; i <= rear; i++)
            printf("%d ", q[i]);
    }
}



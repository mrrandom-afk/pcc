#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node *next;
};

struct node *top = NULL;

void push() {
    struct node *n = malloc(sizeof(struct node));
    if (!n) return;

    printf("Enter data: ");
    scanf("%d", &n->data);

    n->next = top;
    top = n;
}

void pop() {
    if (!top) {
        printf("Underflow\n");
        return;
    }

    struct node *t = top;
    printf("Popped: %d\n", t->data);
    top = top->next;
    free(t);
}

void display() {
    struct node *t = top;

    if (!t) {
        printf("Empty\n");
        return;
    }

    while (t) {
        printf("%d -> ", t->data);
        t = t->next;
    }
    printf("NULL\n");
}

int main() {
    int ch;

    while (1) {
        printf("\n1.Push 2.Pop 3.Display 4.Exit\n");
        scanf("%d", &ch);

        if (ch == 1) push();
        else if (ch == 2) pop();
        else if (ch == 3) display();
        else break;
    }

    return 0;
}



